package com.example.swipablecatalogueapp;

import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.ImageView;
import android.widget.TextView;

import androidx.annotation.NonNull;
import androidx.recyclerview.widget.RecyclerView;

import java.util.List;

// adapter for viewpager2 to display catalogue pages
class ViewPagerAdapter extends RecyclerView.Adapter<ViewPagerAdapter.PageViewHolder> {

    // list of catalogue pages
    private List<CataloguePage> items;

    // constructor to initialize items
    public ViewPagerAdapter(List<CataloguePage> items) {
        this.items = items;
    }

    @NonNull
    @Override
    public PageViewHolder onCreateViewHolder(@NonNull ViewGroup parent, int viewType) {
        // inflate layout for each page item
        View v = LayoutInflater.from(parent.getContext()).inflate(R.layout.item_thumbnail, parent, false);
        return new PageViewHolder(v);
    }

    @Override
    public void onBindViewHolder(@NonNull PageViewHolder holder, int position) {
        // bind data to view elements
        CataloguePage item = items.get(position);
        holder.title.setText(item.getTitle());      // set page title
        holder.desc.setText(item.getDescription()); // set page description
        holder.image.setImageResource(item.getImageResId()); // set page image
    }

    @Override
    public int getItemCount() {
        return items.size(); // return total number of pages
    }

    // view holder class for each page item
    static class PageViewHolder extends RecyclerView.ViewHolder {
        ImageView image;
        TextView title, desc;

        PageViewHolder(@NonNull View itemView) {
            super(itemView);
            // bind view elements
            image = itemView.findViewById(R.id.page_image);
            title = itemView.findViewById(R.id.page_title);
            desc = itemView.findViewById(R.id.page_description);
        }
    }
}
